# Copy this to .env and fill in your values
# NEVER commit .env to GitHub

# Anthropic API (from your existing setup)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Fergus API (from your existing setup)
FERGUS_API_KEY=fergPAT_...

# Supabase (get from supabase.com dashboard)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# JWT secret (make up a long random string)
JWT_SECRET=change-this-to-something-very-random-and-long

# Stripe (get from stripe.com dashboard)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Pricing - Stripe price IDs (create in Stripe dashboard)
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# Frontend URL (your Vercel URL once deployed)
FRONTEND_URL=https://floodroofing.vercel.app

# Port
PORT=3456
